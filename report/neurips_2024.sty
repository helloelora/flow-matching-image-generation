% neurips_2024.sty — NeurIPS 2024 style (two-column variant)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 style]

\newif\if@nonatbib\@nonatbibfalse
\DeclareOption{nonatbib}{\@nonatbibtrue}
\ProcessOptions\relax

% Fonts
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{times}

% Page layout — NeurIPS two-column
\RequirePackage[letterpaper,top=1in,bottom=1in,left=0.75in,right=0.75in]{geometry}

% natbib
\if@nonatbib\else
  \RequirePackage[round,sort&compress,numbers]{natbib}
\fi

% Headers
\RequirePackage{fancyhdr}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\pagestyle{fancy}

% Store abstract text, then render title+abstract together in \twocolumn[]
\newsavebox{\@neuripsabstractbox}
\renewenvironment{abstract}{%
  \global\setbox\@neuripsabstractbox\vbox\bgroup\small%
}{%
  \egroup%
}

% Title formatting — spans both columns, includes abstract
\def\@maketitle{%
  \twocolumn[%
    \begin{center}%
      {\Large\bfseries \@title \par}%
      \vskip 1em%
      {\normalsize
        \lineskip .5em%
        \begin{tabular}[t]{c}%
          \@author
        \end{tabular}\par}%
      \vskip 1.5em%
      {\bfseries\small Abstract}%
    \end{center}%
    \begin{quote}\small%
      \usebox\@neuripsabstractbox%
    \end{quote}%
    \vskip 1em%
  ]%
}

% Section formatting
\RequirePackage[compact]{titlesec}
\titleformat{\section}{\normalsize\bfseries}{\thesection}{0.5em}{}
\titleformat{\subsection}{\small\bfseries}{\thesubsection}{0.5em}{}
\titlespacing{\section}{0pt}{1.5ex plus 0.5ex}{0.5ex plus 0.2ex}
\titlespacing{\subsection}{0pt}{1ex plus 0.3ex}{0.3ex plus 0.1ex}

% Compact spacing
\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}
\setlength{\textfloatsep}{8pt plus 2pt minus 2pt}
\setlength{\floatsep}{6pt plus 2pt minus 2pt}
\setlength{\intextsep}{6pt plus 2pt minus 2pt}
\setlength{\abovecaptionskip}{4pt}
\setlength{\belowcaptionskip}{2pt}

\endinput